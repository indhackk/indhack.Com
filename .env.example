# ===========================================
# INDHACK - Variables d'environnement
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs

# ---- Sécurité Admin ----
ADMIN_PASSWORD=votre_mot_de_passe_securise

# ---- GMB AutoPilot Auth (mot de passe pour l'outil SaaS) ----
NEXT_PUBLIC_GMB_ADMIN_PASSWORD=votre_mot_de_passe_gmb

# ---- APIs de formulaire ----
WEB3FORMS_ACCESS_KEY=votre_cle_web3forms
FORMSUBMIT_EMAIL=contact@indhack.com

# ---- Analytics (optionnel) ----
NEXT_PUBLIC_GA_ID=G-SXXS2G2753

# ---- Unsplash (pour images villes - optionnel) ----
UNSPLASH_ACCESS_KEY=

# ---- Production ----
NEXT_PUBLIC_SITE_URL=https://indhack.com

# IndexNow API Key
INDEXNOW_KEY=your_indexnow_key_here
